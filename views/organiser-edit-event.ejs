<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Event</title>
    <link rel="stylesheet" href="/main.css">
</head>

<body>

    <!-- Navigation -->

    <div class="navbar">
        <h1>Organiser Event Editor</h1>

        <a href="/organiser" class="btn btn-secondary">
            ← Back to Dashboard
        </a>
    </div>

    <div class="container">

        <!-- Event Summary -->

        <div class="card">

            <h2>Edit Event</h2>

            <p>
                Create or update the event details before publishing.
            </p>

            <br>

            <p>
                <strong>Created:</strong>
                <%= event.created_at %>
            </p>

            <% if(event.updated_at){ %>

                <p>
                    <strong>Last Updated:</strong>
                    <%= event.updated_at %>
                </p>

            <% } %>

        </div>

        <form action="/organiser/event/<%= event.event_id %>" method="POST">

            <!-- Event Information -->

            <div class="card">

                <h2>Event Information</h2>

                <div class="form-group">

                    <label for="title">
                        Event Title
                    </label>

                    <input
                        type="text"
                        id="title"
                        name="title"
                        value="<%= event.title %>"
                        required>

                </div>

                <div class="form-group">

                    <label for="description">
                        Event Description
                    </label>

                    <textarea
                        id="description"
                        name="description"
                        rows="6"
                        required><%= event.description %></textarea>

                </div>

                <div class="form-group">

                    <label for="event_date">
                        Event Date
                    </label>

                    <input
                        type="date"
                        id="event_date"
                        name="event_date"
                        value="<%= event.event_date %>"
                        required>

                </div>

            </div>

            <!-- Ticket Information -->

            <div class="card">

                <h2>Ticket Information</h2>

                <div class="form-group">

                    <label for="full_ticket_qty">
                        Full Price Ticket Quantity
                    </label>

                    <input
                        type="number"
                        id="full_ticket_qty"
                        name="full_ticket_qty"
                        min="0"
                        value="<%= event.full_ticket_qty %>"
                        required>

                </div>

                <div class="form-group">

                    <label for="full_ticket_price">
                        Full Ticket Price (Kshs)
                    </label>

                    <input
                        type="number"
                        step="0.01"
                        min="0"
                        id="full_ticket_price"
                        name="full_ticket_price"
                        value="<%= event.full_ticket_price %>"
                        required>

                </div>

                <div class="form-group">

                    <label for="concession_ticket_qty">
                        Concession Ticket Quantity
                    </label>

                    <input
                        type="number"
                        id="concession_ticket_qty"
                        name="concession_ticket_qty"
                        min="0"
                        value="<%= event.concession_ticket_qty %>"
                        required>

                </div>

                <div class="form-group">

                    <label for="concession_ticket_price">
                        Concession Ticket Price (Kshs)
                    </label>

                    <input
                        type="number"
                        step="0.01"
                        min="0"
                        id="concession_ticket_price"
                        name="concession_ticket_price"
                        value="<%= event.concession_ticket_price %>"
                        required>

                </div>

            </div>

            <!-- Actions -->

            <div class="card">

                <button
                    type="submit"
                    class="btn btn-success">
                    💾 Save Changes
                </button>

                <a
                    href="/organiser"
                    class="btn btn-secondary">
                    ← Cancel
                </a>

            </div>

        </form>

        <!-- Footer Navigation -->

        <div style="text-align:center; margin-top:30px;">

            <a href="/organiser" class="btn btn-secondary">
                ← Return to Dashboard
            </a>

            <a href="/" class="btn btn-primary">
                🏠 Home
            </a>

        </div>

    </div>

</body>

</html>