<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Site Settings</title>
    <link rel="stylesheet" href="/main.css">
</head>

<body>

    <div class="navbar">
        <h1>Site Settings</h1>
    </div>

    <div class="container">

        <div class="card">

            <h2>Update Event Manager Details</h2>

            <p>
                Configure the name and description displayed
                to attendees on the public event pages.
            </p>

            <br>

            <form action="/settings/update" method="POST">

                <div class="form-group">

                    <label for="site_name">
                        Site Name
                    </label>

                    <input
                        type="text"
                        id="site_name"
                        name="site_name"
                        value="<%= settings.site_name %>"
                        required>

                </div>

                <div class="form-group">

                    <label for="site_description">
                        Site Description
                    </label>

                    <textarea
                        id="site_description"
                        name="site_description"
                        required><%= settings.site_description %></textarea>

                </div>

                <button
                    type="submit"
                    class="btn btn-success">
                    Save Changes
                </button>

                <a
                    href="/organiser"
                    class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</body>

</html>